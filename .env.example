# Local MLflow connection settings. Copy this file to `.env` and fill in the
# real values so locally-run `qset-compile` logs to the same hosted server
# that CI uses. `.env` is gitignored; never commit real credentials.
#
# These must match the secrets configured on the GitHub project.

# The hosted MLflow tracking server (same URL as the GitHub MLFLOW_TRACKING_URI secret).
MLFLOW_TRACKING_URI=https://your-mlflow-server.example.com

# Credentials, if the server requires HTTP basic auth. Leave unset otherwise.
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=

# Experiment name (optional; defaults to "qiskit-compilation").
MLFLOW_EXPERIMENT_NAME=qiskit-compilation
